# Copy this to .env.local and fill in your values

# Resend API key for sending enquiry emails
# Get one at https://resend.com (free tier covers this easily)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google Analytics 4 — Measurement ID
# Find at: Google Analytics → Admin → Data Streams → your stream → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads — Tag ID
# Find at: Google Ads → Tools → Data manager → Google tag → Your Google tag ID
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX

# Google Ads — Conversion label for form submissions
# Find at: Google Ads → Goals → Conversions → your conversion action → Tag setup → Use Google tag → Conversion label
NEXT_PUBLIC_ADS_CONVERSION_LABEL=AbCdEfGhIj
